{
  "name": "officeno-desktop",
  "version": "1.0.0",
  "description": "Offline Electron desktop app for client, booking, and document management",
  "main": "app/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "lint": "echo 'No lint configured'"
  },
  "build": {
    "appId": "com.officeno.desktop",
    "productName": "Officeno Admin Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0"
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3"
  }
}
